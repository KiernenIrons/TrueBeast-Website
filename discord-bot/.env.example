# Copy this to .env for local testing (never commit .env to GitHub)
# In Railway, add these under Settings → Variables

# Your Discord bot token — same one in your Cloudflare Worker secrets
DISCORD_BOT_TOKEN=paste_your_bot_token_here

# Your Discord server ID — same one in your Cloudflare Worker secrets
DISCORD_GUILD_ID=paste_your_guild_id_here

# The voice channel the bot should join (right-click channel → Copy Channel ID)
# Make sure Developer Mode is on: Discord Settings → Advanced → Developer Mode
VOICE_CHANNEL_ID=paste_the_voice_channel_id_here

# (Optional) Override the default lofi stream URL
# Default is SomaFM Groove Salad — free, legal, reliable since 2000
# Other options:
#   http://ice1.somafm.com/lush-128-mp3              (chilled indie/electronic)
#   http://ice1.somafm.com/dronezone-256-mp3         (ambient/atmospheric)
#   https://streams.ilovemusic.de/iloveradio17.mp3   (lofi hip hop)
# STREAM_URL=http://ice1.somafm.com/groovesalad-256-mp3
