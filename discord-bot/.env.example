# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Discord bot token — from https://discord.com/developers/applications → Your App → Bot → Token
DISCORD_BOT_TOKEN=your-bot-token-here

# Channel ID(s) to monitor. Right-click a channel in Discord → Copy Channel ID.
# Comma-separate for multiple channels, e.g.: 123456789,987654321
SUPPORT_CHANNEL_ID=your-channel-id-here

# Claude API key — from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Firebase — from https://console.firebase.google.com → Project Settings → Your apps
FIREBASE_PROJECT_ID=truebeast-support
FIREBASE_API_KEY=your-firebase-web-api-key-here
