# HTML pages — always check for a fresh copy (no stale pages for visitors)
/*.html
  Cache-Control: no-cache, must-revalidate

# Root index
/
  Cache-Control: no-cache, must-revalidate

# CSS / JS / assets — cache for 1 year (they use ?v= version strings so updates bust the cache)
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
